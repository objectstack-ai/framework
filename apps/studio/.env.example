# Environment Variables for Development
# Copy this file to .env.local and customize
#
# NOTE: .env.production is used for production builds (e.g., server deployment)

# Runtime Mode: 'msw' (default for dev) | 'server'
# - 'msw': Mock Service Worker with in-browser kernel (recommended for local dev)
# - 'server': Connect to real ObjectStack server
# Also overridable via URL: ?mode=msw|server
VITE_RUNTIME_MODE=msw

# ObjectStack Server URL (used in server mode)
# The client adds /api/v1/... internally
# Leave empty for same-origin (embedded /_studio/ mode)
# VITE_SERVER_URL=http://localhost:5000
