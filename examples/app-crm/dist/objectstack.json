{
  "manifest": {
    "id": "com.example.crm",
    "namespace": "crm",
    "defaultDatasource": "default",
    "version": "4.0.0",
    "type": "app",
    "scope": "project",
    "name": "CRM (minimal example)",
    "description": "Minimal CRM workspace used by the framework to validate the metadata loading pipeline end-to-end."
  },
  "objects": [
    {
      "name": "crm_account",
      "label": "Account",
      "pluralLabel": "Accounts",
      "description": "A company that the org sells to or supports.",
      "icon": "building",
      "active": true,
      "isSystem": false,
      "abstract": false,
      "datasource": "default",
      "fields": {
        "name": {
          "label": "Account Name",
          "type": "text",
          "required": true,
          "searchable": true,
          "multiple": false,
          "unique": false,
          "maxLength": 200,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "industry": {
          "label": "Industry",
          "type": "select",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "options": [
            {
              "label": "Technology",
              "value": "technology",
              "default": true
            },
            {
              "label": "Finance",
              "value": "finance"
            },
            {
              "label": "Healthcare",
              "value": "healthcare"
            },
            {
              "label": "Retail",
              "value": "retail"
            },
            {
              "label": "Other",
              "value": "other"
            }
          ],
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "annual_revenue": {
          "label": "Annual Revenue",
          "type": "currency",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "scale": 2,
          "min": 0,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "website": {
          "label": "Website",
          "type": "url",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        }
      }
    },
    {
      "name": "crm_contact",
      "label": "Contact",
      "pluralLabel": "Contacts",
      "description": "A person associated with an account.",
      "icon": "user",
      "active": true,
      "isSystem": false,
      "abstract": false,
      "datasource": "default",
      "fields": {
        "first_name": {
          "label": "First Name",
          "type": "text",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "maxLength": 80,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "last_name": {
          "label": "Last Name",
          "type": "text",
          "required": true,
          "searchable": true,
          "multiple": false,
          "unique": false,
          "maxLength": 80,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "full_name": {
          "label": "Full Name",
          "type": "formula",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "deleteBehavior": "set_null",
          "expression": {
            "dialect": "cel",
            "source": "(first_name == null ? '' : first_name + ' ') + last_name"
          },
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "email": {
          "label": "Email",
          "type": "email",
          "required": false,
          "searchable": true,
          "multiple": false,
          "unique": false,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "account": {
          "label": "Account",
          "type": "lookup",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "reference": "crm_account",
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        }
      }
    },
    {
      "name": "crm_opportunity",
      "label": "Opportunity",
      "pluralLabel": "Opportunities",
      "description": "A potential sale tied to an account.",
      "icon": "trending-up",
      "active": true,
      "isSystem": false,
      "abstract": false,
      "datasource": "default",
      "fields": {
        "name": {
          "label": "Opportunity Name",
          "type": "text",
          "required": true,
          "searchable": true,
          "multiple": false,
          "unique": false,
          "maxLength": 200,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "account": {
          "label": "Account",
          "type": "lookup",
          "required": true,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "reference": "crm_account",
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "stage": {
          "label": "Stage",
          "type": "select",
          "required": true,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "options": [
            {
              "label": "Prospecting",
              "value": "prospecting",
              "color": "#94A3B8",
              "default": true
            },
            {
              "label": "Qualification",
              "value": "qualification",
              "color": "#3B82F6"
            },
            {
              "label": "Proposal",
              "value": "proposal",
              "color": "#F59E0B"
            },
            {
              "label": "Closed Won",
              "value": "closed_won",
              "color": "#10B981"
            },
            {
              "label": "Closed Lost",
              "value": "closed_lost",
              "color": "#EF4444"
            }
          ],
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "amount": {
          "label": "Amount",
          "type": "currency",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "scale": 2,
          "min": 0,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "probability": {
          "label": "Probability",
          "type": "percent",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "defaultValue": 50,
          "min": 0,
          "max": 100,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "expected_revenue": {
          "label": "Expected Revenue",
          "type": "formula",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "deleteBehavior": "set_null",
          "expression": {
            "dialect": "cel",
            "source": "(amount == null ? 0 : amount) * (probability == null ? 0 : probability) / 100"
          },
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        },
        "close_date": {
          "label": "Close Date",
          "type": "date",
          "required": false,
          "searchable": false,
          "multiple": false,
          "unique": false,
          "deleteBehavior": "set_null",
          "auditTrail": false,
          "hidden": false,
          "readonly": false,
          "sortable": true,
          "index": false,
          "externalId": false
        }
      }
    }
  ],
  "apps": [
    {
      "name": "crm_app",
      "label": "CRM",
      "icon": "briefcase",
      "branding": {
        "primaryColor": "#2563EB"
      },
      "active": true,
      "isDefault": false,
      "navigation": [
        {
          "id": "group_sales",
          "label": "Sales",
          "icon": "briefcase",
          "type": "group",
          "expanded": false,
          "children": [
            {
              "id": "nav_accounts",
              "label": "Accounts",
              "icon": "building",
              "type": "object",
              "objectName": "crm_account"
            },
            {
              "id": "nav_contacts",
              "label": "Contacts",
              "icon": "user",
              "type": "object",
              "objectName": "crm_contact"
            },
            {
              "id": "nav_opportunities",
              "label": "Opportunities",
              "icon": "trending-up",
              "type": "object",
              "objectName": "crm_opportunity"
            }
          ]
        },
        {
          "id": "group_analytics",
          "label": "Analytics",
          "icon": "chart-bar",
          "type": "group",
          "expanded": false,
          "children": [
            {
              "id": "nav_pipeline_dashboard",
              "label": "Pipeline",
              "icon": "layout-dashboard",
              "type": "dashboard",
              "dashboardName": "pipeline_dashboard"
            }
          ]
        }
      ]
    }
  ],
  "views": [
    {
      "listViews": {
        "all": {
          "label": "All Opportunities",
          "type": "grid",
          "columns": [
            {
              "field": "name"
            },
            {
              "field": "account"
            },
            {
              "field": "stage"
            },
            {
              "field": "amount"
            },
            {
              "field": "probability"
            },
            {
              "field": "expected_revenue"
            },
            {
              "field": "close_date"
            }
          ]
        },
        "pipeline": {
          "label": "Pipeline (Kanban)",
          "type": "kanban",
          "columns": [
            "name",
            "account",
            "amount",
            "close_date"
          ],
          "kanban": {
            "groupByField": "stage",
            "summarizeField": "amount",
            "columns": [
              "name",
              "account",
              "amount",
              "close_date"
            ]
          }
        }
      },
      "formViews": {
        "default": {
          "type": "simple",
          "sections": [
            {
              "label": "Opportunity",
              "collapsible": false,
              "collapsed": false,
              "columns": 2,
              "fields": [
                {
                  "field": "name",
                  "required": true
                },
                {
                  "field": "account",
                  "required": true
                },
                {
                  "field": "stage",
                  "required": true
                },
                {
                  "field": "amount"
                },
                {
                  "field": "probability"
                },
                {
                  "field": "close_date"
                }
              ]
            }
          ]
        }
      }
    }
  ],
  "dashboards": [
    {
      "name": "pipeline_dashboard",
      "label": "Pipeline Dashboard",
      "description": "Aggregate view of the sales pipeline with period-over-period comparisons.",
      "widgets": [
        {
          "id": "total_pipeline",
          "title": "Total Pipeline ($)",
          "description": "Sum of opportunity amounts across open stages.",
          "type": "metric",
          "object": "crm_opportunity",
          "filter": {
            "stage": {
              "$nin": [
                "closed_won",
                "closed_lost"
              ]
            }
          },
          "valueField": "amount",
          "aggregate": "sum",
          "layout": {
            "x": 0,
            "y": 0,
            "w": 4,
            "h": 2
          },
          "options": {
            "format": "currency",
            "currency": "USD"
          }
        },
        {
          "id": "won_this_quarter",
          "title": "Won This Quarter",
          "description": "Revenue closed-won in the current quarter, compared to the previous quarter.",
          "type": "metric",
          "object": "crm_opportunity",
          "filter": {
            "stage": "closed_won",
            "close_date": {
              "$gte": "{current_quarter_start}",
              "$lte": "{current_quarter_end}"
            }
          },
          "compareTo": "previousPeriod",
          "valueField": "amount",
          "aggregate": "sum",
          "layout": {
            "x": 4,
            "y": 0,
            "w": 4,
            "h": 2
          },
          "options": {
            "format": "currency",
            "currency": "USD"
          }
        },
        {
          "id": "avg_deal_size_yoy",
          "title": "Avg Deal Size (YoY)",
          "description": "Average won-deal value this year vs the same window last year.",
          "type": "metric",
          "object": "crm_opportunity",
          "filter": {
            "stage": "closed_won",
            "close_date": {
              "$gte": "{current_year_start}",
              "$lte": "{current_year_end}"
            }
          },
          "compareTo": "previousYear",
          "valueField": "amount",
          "aggregate": "avg",
          "layout": {
            "x": 8,
            "y": 0,
            "w": 4,
            "h": 2
          },
          "options": {
            "format": "currency",
            "currency": "USD"
          }
        },
        {
          "id": "pipeline_trend_90d",
          "title": "Pipeline Trend (12 months)",
          "description": "Opportunity count bucketed by close-month for the last year, with a sliding overlay of the prior year for compareTo.",
          "type": "line",
          "object": "crm_opportunity",
          "filter": {
            "close_date": {
              "$gte": "{1_years_ago}",
              "$lte": "{today}"
            }
          },
          "compareTo": "previousYear",
          "categoryField": "close_date",
          "categoryGranularity": "month",
          "aggregate": "count",
          "layout": {
            "x": 0,
            "y": 2,
            "w": 8,
            "h": 4
          }
        },
        {
          "id": "opportunities_by_stage",
          "title": "Opportunities by Stage",
          "description": "Count grouped by stage with previous-quarter overlay (compareTo).",
          "type": "bar",
          "object": "crm_opportunity",
          "filter": {
            "close_date": {
              "$gte": "{current_quarter_start}",
              "$lte": "{current_quarter_end}"
            }
          },
          "compareTo": "previousPeriod",
          "categoryField": "stage",
          "aggregate": "count",
          "layout": {
            "x": 8,
            "y": 2,
            "w": 4,
            "h": 4
          }
        },
        {
          "id": "pipeline_by_industry",
          "title": "Open Pipeline by Stage ($)",
          "description": "Open-pipeline revenue split by pipeline stage. Pie/donut/funnel ignore `compareTo`.",
          "type": "pie",
          "object": "crm_opportunity",
          "filter": {
            "stage": {
              "$nin": [
                "closed_won",
                "closed_lost"
              ]
            }
          },
          "categoryField": "stage",
          "valueField": "amount",
          "aggregate": "sum",
          "layout": {
            "x": 0,
            "y": 6,
            "w": 6,
            "h": 4
          }
        }
      ],
      "columns": 12
    }
  ],
  "flows": [
    {
      "name": "opportunity_won_notification",
      "label": "Notify on Opportunity Won",
      "description": "Sends a celebration email when an opportunity is closed-won.",
      "version": 1,
      "status": "draft",
      "template": false,
      "type": "autolaunched",
      "nodes": [
        {
          "id": "start",
          "type": "start",
          "label": "On Opportunity Update",
          "config": {
            "objectName": "crm_opportunity",
            "triggerType": "record-after-update",
            "condition": "stage == \"closed_won\" && previous.stage != \"closed_won\""
          }
        },
        {
          "id": "send_email",
          "type": "script",
          "label": "Send Win Notification",
          "config": {
            "actionType": "email",
            "inputs": {
              "to": "{record.owner.email}",
              "subject": "🎉 Opportunity Won: {record.name}",
              "template": "opportunity_won_email"
            }
          }
        },
        {
          "id": "end",
          "type": "end",
          "label": "End"
        }
      ],
      "edges": [
        {
          "id": "e1",
          "source": "start",
          "target": "send_email",
          "type": "default",
          "isDefault": false
        },
        {
          "id": "e2",
          "source": "send_email",
          "target": "end",
          "type": "default",
          "isDefault": false
        }
      ],
      "active": false,
      "runAs": "user"
    }
  ],
  "hooks": [
    {
      "name": "opportunity_stage_probability",
      "object": "crm_opportunity",
      "events": [
        "beforeInsert",
        "beforeUpdate"
      ],
      "handler": "opportunity_stage_probability",
      "body": {
        "language": "js",
        "source": "\n    const input = ctx.input;\n    if (input.stage === \"closed_won\") input.probability = 100;\n    if (input.stage === \"closed_lost\") input.probability = 0;\n  ",
        "capabilities": []
      },
      "priority": 100,
      "async": false,
      "onError": "abort"
    }
  ],
